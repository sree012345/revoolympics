# Revo Olympics — example environment variables
# Copy to .env for local development. Never commit real .env files.

REVO_ENV=development
FIREBASE_PROJECT_ID=revoolympics-dev
USE_FIREBASE_EMULATORS=false

# Hosting base URLs (development defaults)
ADMIN_HOST_URL=https://revoolympics-admin-dev.web.app
GAME_HOST_URL=https://revoolympics-games-dev.web.app
PLAYER_HOST_URL=https://revoolympics-player-dev.web.app

# Cloud Functions
REVO_FUNCTIONS_REGION=asia-south1

ENABLE_DEBUG_LOGGING=true

# Production deployment (CI only — never set locally without approval)
# PRODUCTION_DEPLOY_APPROVED=false
# RELEASE_TAG=
