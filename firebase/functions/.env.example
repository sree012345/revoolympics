# Cloud Functions — example non-secret parameters
# Copy to .env.<environment> locally. Never commit real secrets.

REVO_ENV=development
FIREBASE_PROJECT_ID=revoolympics-dev
FUNCTIONS_REGION=asia-south1
ADMIN_BASE_URL=https://revoolympics-admin-dev.web.app
GAME_BASE_URL=https://revoolympics-games-dev.web.app
ENABLE_DEBUG_LOGGING=true

# Secrets belong in Secret Manager, not here.
